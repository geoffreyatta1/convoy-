{
  "expo": {
    "name": "Family Convoy Navigator",
    "slug": "convoy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "convoy"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geoffreyatta.convoy",
      "buildNumber": "1",
      "backgroundModes": [
        "audio",
        "location"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Convoy needs your location to show your position to other convoy members.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Convoy needs your location in the background so other convoy members can always see where you are.",
        "NSMicrophoneUsageDescription": "Convoy needs the microphone for push-to-talk between convoy vehicles.",
        "UIBackgroundModes": [
          "audio",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleMapsApiKey": "AIzaSyB2PrKbDG9D5q10k54ipEF9nb6sUsZWj4k"
      }
    },
    "android": {
      "package": "com.geoffreyatta.convoy",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2PrKbDG9D5q10k54ipEF9nb6sUsZWj4k"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "react-native-maps",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-location",
      "./plugins/withConvoyAudio",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e19eebf5-95ef-4267-9b3e-f77182c77f9c"
      }
    },
    "owner": "geoffreyatta1"
  }
}
